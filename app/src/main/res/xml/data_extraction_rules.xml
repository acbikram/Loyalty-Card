<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ data extraction rules for cloud backup and device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="universal_loyalty_wallet.db" />
        <exclude domain="sharedpref" path="secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="universal_loyalty_wallet.db" />
        <exclude domain="sharedpref" path="secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
