<?xml version="1.0" encoding="utf-8"?>
<!--
  Per-app language list (Android 13+ system language picker). The OS reads this
  to offer in-Settings language selection with no app code required. Add a
  <locale> here whenever a new translation ships.
-->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <locale android:name="en" />
    <locale android:name="ar" />
</locale-config>
