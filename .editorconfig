# EditorConfig + ktlint rules for Universal Loyalty Wallet.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 140

[*.{kt,kts}]
ktlint_code_style = android_studio
# Compose @Composable functions are PascalCase; don't flag them as function-naming violations.
ktlint_function_naming_ignore_when_annotated_with = Composable, Preview
# Allow trailing commas (matches the codebase + Kotlin style).
ktlint_standard_trailing-comma-on-call-site = enabled
ktlint_standard_trailing-comma-on-declaration-site = enabled
# Wildcard imports are disallowed; keep imports explicit.
ij_kotlin_name_count_to_use_star_import = 2147483647
ij_kotlin_name_count_to_use_star_import_for_members = 2147483647

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
